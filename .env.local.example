# VALORAIPLUS® - ENVIRONMENT TEMPLATE
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to git. It is listed in .gitignore.

# ─── Base Mainnet ────────────────────────────────────────────────────────────
BASE_RPC_URL=https://mainnet.base.org
BASESCAN_API_KEY=

# ─── Deployer (nonce:reconcile only) ─────────────────────────────────────────
# WARNING: Never share or commit this value.
# Export via terminal only: export DEPLOYER_PRIVATE_KEY=0x...
# Do NOT store a real private key in this file.
DEPLOYER_PRIVATE_KEY=

# ─── Factory (read-only reference — do not change) ───────────────────────────
NEXT_PUBLIC_FACTORY_ADDRESS=0x7fAA2FA0b1388b2c8696475d0e08F54F36818FD1
NEXT_PUBLIC_CHAIN_ID=8453

# ─── App ─────────────────────────────────────────────────────────────────────
APP_BASE_URL=https://your-vercel-deployment-url.vercel.app
NODE_ENV=development

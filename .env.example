# =============================================================================
# VALORAIPLUS — Required Environment Variables
# Copy this file to .env.local for local development.
# All 5 variables must be present in Vercel project settings before deployment.
# =============================================================================

# --- Supabase (required for both Phase 1 and Phase 2) ---

# Public URL of your Supabase project. Found in Supabase Dashboard > Settings > API.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Public anon key. Safe to expose to the browser. Used for read-only RLS queries.
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key. SERVER-SIDE ONLY. Never expose to the browser.
# Used by the access-log API route to bypass RLS and write telemetry rows.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- VALORAIPLUS Telemetry (required for Phase 2) ---

# 32-byte+ random secret used to HMAC-SHA256 hash raw IP and User-Agent values
# before storage. Raw values are NEVER stored. This salt must be consistent
# across all edge nodes to produce stable, comparable visitor hashes.
# Generate with: openssl rand -hex 32
AUDIT_HASH_SECRET=replace_with_64_char_hex_secret

# Bearer token required on all POST requests to /api/valoraiplus/access-log.
# The middleware emits this header; the route validates it before any DB write.
# Generate with: openssl rand -hex 32
VALORAIPLUS_INGEST_KEY=replace_with_64_char_hex_key

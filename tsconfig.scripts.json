{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "outDir": "./dist-scripts",
    "baseUrl": "."
  },
  "include": ["scripts/**/*.ts", "lib/**/*.ts", "contracts/**/*.ts"]
}
